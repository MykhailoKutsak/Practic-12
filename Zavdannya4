#include <iostream>
#include <cmath>

int main() {
int count = 0;

for (int i = 0; i <= 90; i++) {
double rad = i * 3.14159 / 180; // перевід у радіани
double s = sin(rad);

std::cout << s << " ";

count++;

// Кожні 10 значень — новий рядок
if (count % 10 == 0) {
std::cout << std::endl;
}
}

return 0;
}
